{% extends 'layouts/app.jinja2' %}
{% import 'macros/form.jinja2' as f with context %}
{% import 'macros/topbar.jinja2' as topbar %}
{% import 'macros/modals.jinja2' as modals %}
{% import 'macros/detail.jinja2' as detail %}

{% block title %}Agregar Destinatarios a {{ ofi_documento.descripcion | truncate(48) }}{% endblock %}

{% block custom_head %}
    <!-- Select2 bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://storage.googleapis.com/pjecz-informatica/static/css/select2.css" rel="stylesheet" />
{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons('Agregar Destinatario a ' + ofi_documento.descripcion | truncate(48)) %}
        {{ topbar.button_previous('Regresar al Oficio', url_for('ofi_documentos.detail', ofi_documento_id=ofi_documento.id)) }}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call f.card(title='Oficio') %}
        {% if current_user.can_view('OFI DOCUMENTOS') %}
            {{ detail.label_value('Descripción', ofi_documento.descripcion, url_for('ofi_documentos.detail', ofi_documento_id=ofi_documento.id)) }}
        {% else %}
            {{ detail.label_value('Descripción', ofi_documento.descripcion) }}
        {% endif %}
        {{ detail.label_value('Folio', ofi_documento.folio) }}
        {% set propietario_nombre_email = ofi_documento.usuario.nombre + ' (' + ofi_documento.usuario.email + ')' %}
        {% if current_user.can_view('USUARIOS') %}
            {{ detail.label_value('Propietario', propietario_nombre_email,  url_for("usuarios.detail", usuario_id=ofi_documento.usuario.id)) }}
        {% else %}
            {{ detail.label_value('Propietario', propietario_nombre_email) }}
        {% endif %}
    {% endcall %}
    {% call f.card(title='Agregar Destinatarios') %}
        <!-- Formulario Agregar Destinatario -->
        {% set form_kwargs = {'ofi_documento_id': ofi_documento.id} %}
        {% call f.form_tag('ofi_documentos_destinatarios.new_with_ofi_documento', fid='ofi_documento_destinatario_form', **form_kwargs) %}
            <div class="form-group mb-2">
                <label><strong>Agregar un usuario</strong></label>
            </div>
            <div class="row">
                <div class="col-8">
                    <label for="usuario" class="visually-hidden">Usuario</label>
                    <select class="form-control" id="usuario" name="usuario" placeholder="Usuario"></select>
                </div>
                <div class="col-2">
                    <div class="checkbox ">
                        <input id="con_copia" name="con_copia" type="checkbox"> <label for="con_copia">Con Copia</label>
                    </div>
                </div>
                <div class="col-2 text-end">
                    <a class="btn btn-primary" id="guardar" name="guardar" type="submit" onclick="ofi_documento_destinatario_form.submit()"><span class="iconify" data-icon="mdi:plus"></span> Agregar</a>
                </div>
            </div>
        {% endcall %}
        <hr />
        <!-- DataTable Destinatarios -->
        <table id="ofi_documentos_destinatarios_datatable" class="table display nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Correo electrónico</th>
                    <th>Nombre</th>
                    <th>Puesto</th>
                    <th>Leído</th>
                    <th>Con Copia</th>
                    <th>Eliminar/Recuperar</th>
                </tr>
            </thead>
        </table>
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    <!-- Select2 bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function(){
            $("#usuario").select2({
                // --- Carga por Ajax --- //
                ajax: {
                    url: '/usuarios/select2_json',
                    headers: { "X-CSRF-TOKEN": "{{ csrf_token() }}" },
                    dataType: 'json',
                    delay: 250,
                    type: "POST",
                    data: function (params) {
                        return { 'searchString': params.term, "workspace": "LOCAL" }
                    }
                },
                placeholder: "{{buscar}}",
                minimumInputLength: 3,
                allowClear: true
            });
        });
    </script>
    <!-- DataTables -->
    <script src="/static/js/datatables-constructor.js"></script>
    <script src="/static/js/datatables-filtros.js"></script>
    <!-- DataTable Destinatarios -->
    <script>
        const constructorDataTable = new ConfigDataTable( '{{ csrf_token() }}' );
        let configDTOfiDocumentosDestinatarios = constructorDataTable.config();
        configDTOfiDocumentosDestinatarios['ajax']['url'] = '{{ url_for("ofi_documentos_destinatarios.datatable_json") }}';
        configDTOfiDocumentosDestinatarios['ajax']['data'] = {"estatus": "A", "ofi_documento_id": "{{ ofi_documento.id }}"};
        configDTOfiDocumentosDestinatarios['columns'] = [
            { data: 'detalle' },
            { data: 'usuario_nombre' },
            { data: 'usuario_puesto' },
            { data: 'fue_leido' },
            { data: 'con_copia' },
            { data: 'eliminar_recuperar' }
        ];
        configDTOfiDocumentosDestinatarios['columnDefs'] = [
            {
                targets: 0, // detalle
                data: null,
                render: function(data, type, row, meta) {
                    email = data.usuario_email.length > 32 ? data.usuario_email.substring(0, 32) + '…' : data.usuario_email;
                    return '<a href="' + data.url + '">' + email + '</a>';
                }
            },
            {
              targets: [1, 2], // usuario_nombre, usuario_puesto
                data: null,
                render: function(data, type, row, meta) {
                    return data.length > 32 ? data.substring(0, 32) + '…' : data;
                }
            },
            {
                targets: [3, 4], // fue_leido
                data: null,
                render: function(data, type, row, meta) {
                    if (data) {
                        return '<span class="mdi mdi-checkbox-marked" style="font-size: 1.4em"></span>';
                    }
                    return '<span class="mdi mdi-checkbox-blank-outline text-secondary" style="font-size: 1.4em"></span>';
                }
            },
            {
                targets: 5, // eliminar_recuperar
                data: null,
                render: function(data, type, row, meta) {
                    if (data.url === '') {
                        if (data.estatus === "A") {
                            return '<span class="badge bg-primary">Activo</span>';
                        } else {
                            return '<span class="badge bg-secondary">Eliminado</span>';
                        }
                    }
                    let myId = 'ofi_documento_destinatario_' + data.id;
                    let myRow = 'ofi_documento_destinatario_row_' + data.id;
                    let myOnClick = "deleteRecover('#" + myId + "', '" + data.url + "', '#" + myRow + "')";
                    if (data.estatus === "A") {
                        return '<button id="' + myId + '" type="button" class="btn btn-sm btn-outline-primary" onclick="' + myOnClick + '"><span class="mdi mdi-delete"></span></button>';
                    } else {
                        return '<button id="' + myId + '" type="button" class="btn btn-sm btn-light" onclick="' + myOnClick + '"><span class="mdi mdi-delete-restore"></span></button>';
                    }
                }
            }
        ];
        const filtrosDestinatarios = new FiltrosDataTable('#ofi_documentos_destinatarios_datatable', configDTOfiDocumentosDestinatarios);
        filtrosDestinatarios.precargar();
    </script>
    <!-- DataTable Eliminar/Recuperar -->
    <script>
        // Preparar headers para POST
        const myHeaders = new Headers();
        myHeaders.append("X-CSRF-TOKEN", "{{ csrf_token() }}");
        const myInit = {
            method: "POST",
            headers: myHeaders,
            mode: "cors",
            cache: "default",
        };
    </script>
    <script src="{{ url_for('static', filename='js/datatables-delete-recover.js') }}"></script>
{% endblock %}
